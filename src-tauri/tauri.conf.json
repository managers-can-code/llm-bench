{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llm-bench",
  "version": "0.1.0",
  "identifier": "code.managers.llmbench",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "llm-bench",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local LLM runner across llama.cpp + LiteRT-LM",
    "longDescription": "A desktop app that runs open-weight LLMs on llama.cpp and LiteRT-LM, with chat, evals (MMLU, BFCL, τ-Bench, SWE-bench), benchmarks, and side-by-side compare."
  }
}
